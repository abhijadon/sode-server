# ==========================================
# 📦 DEPENDENCIES & RUNTIMES
# ==========================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Bun lock file caches or system files (Optional: keep bun.lock, ignore logs)
*.lockb
bun-debug.log*

# ==========================================
# 🧪 TESTING & COVERAGE
# ==========================================
/coverage
*.lcov
.nyc_output

# ==========================================
# 🏗️ BUILD & PRODUCTION OUTPUTS
# ==========================================
/dist
/build
/.next/
/out/

# ==========================================
# 🔐 CONFIG & SECURITY ENVS (CRITICAL!)
# ==========================================
# आपकी JWT_SECRET, MONGO_URI वाली फ़ाइलें कभी लीक नहीं होनी चाहिए
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.cert

# ==========================================
# 🛠️ DEBUG & SYSTEM LOGS
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# OS generated files (Mac / Windows)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==========================================
# 🖥️ IDE & EDITORS CACHE
# ==========================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?